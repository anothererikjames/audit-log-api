  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\",()=>pm.response.to.have.status(200));",
                  "pm.test(\"Returns data array\",()=>pm.expect(pm.response.json().data).to.be.an(\"array\"));",
                  "pm.test(\"Events have required fields\",()=>{const evts=pm.response.json().data;",
                  "  if(evts.length>0){const e=evts[0];",
                  "    pm.expect(e).to.include.all.keys(\"id\",\"service\",\"action\",\"actorId\",\"occurredAt\");",
                  "    pm.environment.set(\"eventId\",e.id);}});",
                  "pm.test(\"Response time < 800ms\",()=>pm.expect(pm.response.responseTime).to.be.below(800));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events?service=identity&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ],
              "query": [
                {
                  "key": "service",
                  "value": "identity"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            },
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}"
                }
              ]
            }
          },
          "response": [
            {
              "name": "Mock Response",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/events?service=identity&limit=50",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "events"
                  ],
                  "query": [
                    {
                      "key": "service",
                      "value": "identity"
                    },
                    {
                      "key": "limit",
                      "value": "50"
                    }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
