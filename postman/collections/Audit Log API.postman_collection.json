    {
      "name": "Exports",
      "item": [
        {
          "name": "Export Events (CSV)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 202\",()=>pm.response.to.have.status(202));",
                  "pm.test(\"Returns exportId\",()=>{const b=pm.response.json();",
                  "  pm.expect(b.exportId).to.be.a(\"string\");",
                  "  pm.expect(b.estimatedReadyAt).to.be.a(\"string\");",
                  "  pm.environment.set(\"exportId\",b.exportId);});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/events/export",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "export"
              ]
            },
            "header": [
              {
