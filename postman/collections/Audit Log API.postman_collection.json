              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\",()=>pm.response.to.have.status(200));",
                  "pm.test(\"Event ID matches\",()=>pm.expect(pm.response.json().id).to.equal(pm.environment.get(\"eventId\")));",
                  "pm.test(\"Has actor info\",()=>{const b=pm.response.json();",
                  "  pm.expect(b.actorId).to.be.a(\"string\");",
                  "  pm.expect(b.actorType).to.be.oneOf([\"user\",\"service_account\",\"system\"]);});"
                ],
